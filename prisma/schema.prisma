// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  stack        String[]
  sourceUrl    String?
  liveUrl      String?
  imageUrls    String[]
  githubRepo   String?
  githubBranch String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Skill {
  id   String  @id @default(cuid())
  name String
  icon String?
}

model Experience {
  id          String    @id @default(cuid())
  title       String
  company     String
  description String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  order       Int       @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fromName  String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  message   String
  approved  Boolean  @default(false)
  blocked   Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())
}

model GuestbookBlock {
  ip        String   @id
  reason    String
  createdAt DateTime @default(now())
}

model FsNode {
  id        String    @id @default(cuid())
  name      String
  type      String    // "file" | "folder"
  parentId  String?
  parent    FsNode?   @relation("FsTree", fields: [parentId], references: [id])
  children  FsNode[]  @relation("FsTree")
  content   String?
  isPublic  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
